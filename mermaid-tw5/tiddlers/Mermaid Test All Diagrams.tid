!! Requirement Diagram

<$mermaid text="
requirementDiagram
    requirement render_req {
        id: 1
        text: The system shall render diagrams
        risk: low
        verifymethod: test
    }
    functionalRequirement perf_req {
        id: 2
        text: Render in under 500ms
        risk: medium
        verifymethod: demonstration
    }
    element Renderer {
        type: module
    }
    Renderer - satisfies -> render_req
    Renderer - satisfies -> perf_req
"/>

