!! Requirement Diagram

<$mermaid text='''
requirementDiagram
    requirement TestReq {
        id: 1
        text: The system shall render diagrams
        risk: low
        verifymethod: test
    }
    element Renderer {
        type: module
    }
    Renderer - satisfies -> TestReq
'''/>

!! C4 Context

<$mermaid text='''
C4Context
    title System Context
    Person(user, "User", "A wiki user")
    System_Boundary(b1, "Wiki") {
        System(plugin, "Mermaid Plugin", "Renders diagrams")
    }
    Rel(user, plugin, "Creates diagrams")
'''/>

